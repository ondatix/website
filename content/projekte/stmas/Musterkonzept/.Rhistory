# Lade Daten
stichtag_daten <- read_csv(
"Daten/Stichtag_dummy.csv",
col_select = c("Geschlechtsschluessel", "ArbAnteil", "PersNr", "TrfGr",
"ND Organisations Merkmal", "Führungsebene", "Teilzeitgrundschluessel",
"Ab- oder Anwesenheitsart"),
col_types = cols(col_character(), col_integer(), col_integer(), col_character(), col_character(),
col_character(), col_character(), col_character(), col_character())
) %>%
mutate(TrfGr = fct_relevel(TrfGr, str_sort)) %>%
mutate(Jahr = as.factor(2025)) %>%
mutate(Führungsebene = replace_na(Führungsebene, "Keine")) %>%
mutate(Teilzeitgrundschluessel = replace_na(Teilzeitgrundschluessel, "Keine Angabe")) %>%
mutate(Qualifikationsebene = replace_na(`ND Organisations Merkmal`, "Keine Angabe"))
stichtag_daten_2020 <- read_csv(
"Daten/Stichtag_dummy_2020.csv",
col_select = c("Geschlechtsschluessel", "ArbAnteil", "PersNr", "TrfGr",
"ND Organisations Merkmal", "Führungsebene", "Teilzeitgrundschluessel",
"Ab- oder Anwesenheitsart"),
col_types = cols(col_character(), col_integer(), col_integer(), col_factor(), col_character(),
col_character(), col_character(), col_character(), col_character())
) %>%
mutate(TrfGr = fct_relevel(TrfGr, str_sort)) %>%
mutate(Jahr = as.factor(2020)) %>%
mutate(Führungsebene = replace_na(Führungsebene, "Keine")) %>%
mutate(Teilzeitgrundschluessel = replace_na(Teilzeitgrundschluessel, "Keine Angabe")) %>%
mutate(Qualifikationsebene = replace_na(`ND Organisations Merkmal`, "Keine Angabe"))
stichtag_daten_2015 <- read_csv(
"Daten/Stichtag_dummy_2020.csv",
col_select = c("Geschlechtsschluessel", "ArbAnteil", "PersNr", "TrfGr",
"ND Organisations Merkmal", "Führungsebene", "Teilzeitgrundschluessel",
"Ab- oder Anwesenheitsart"),
col_types = cols(col_character(), col_integer(), col_integer(), col_factor(), col_character(),
col_character(), col_character(), col_character(), col_character()),
n_max = 400
) %>%
mutate(TrfGr = fct_relevel(TrfGr, str_sort)) %>%
mutate(Jahr = as.factor(2015)) %>%
mutate(Führungsebene = replace_na(Führungsebene, "Keine")) %>%
mutate(Teilzeitgrundschluessel = replace_na(Teilzeitgrundschluessel, "Keine Angabe")) %>%
mutate(Qualifikationsebene = replace_na(`ND Organisations Merkmal`, "Keine Angabe"))
barrierefreies_balkendiagramm(stichtag_daten, x = "Qualifikationsebene")
daten_beschaeftigungsart <- stichtag_daten %>%
mutate(Beschäftigungsart = ifelse(str_count(TrfGr, "[AB]") > 0, "Verbeamtet", "Angestellt"))
barrierefreies_balkendiagramm(daten_beschaeftigungsart, x = "Beschäftigungsart")
