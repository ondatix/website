barrierefreies_balkendiagramm <- function(data, x, y = "Anzahl", fill = "Geschlechtsschluessel") {
df <- datenvorbereitung(data, c(x, fill))
print(0)
alttext <- alttexterstellung(df, x, fill, y)
print(1)
balkendiagramm(df, x, y, fill, alttext)
}
