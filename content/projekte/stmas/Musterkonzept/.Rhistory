tabellen_datenschutz <- function(x) ifelse(x >= params$kleinstgruppe, paste(x), paste("<", params$kleinstgruppe))
grafik_datenschutz <- function(x) ifelse(x >= params$kleinstgruppe, x, NA)
datenvorbereitung <- function(data, group_vars) {
data %>%
group_by(across(group_vars)) %>%
summarise(Anzahl = n()) %>%
mutate(Anzahl = grafik_datenschutz(Anzahl)) %>%
drop_na()
}
alttexterstellung <- function(data, x_label, fill_label, y_label = "Anzahl") {
alttext <- paste("Ein Balkendiagramm zeigt die Verteilung der", x_label, "in der Dienststelle, differenziert nach", fill_label, ". Die x-Achse repräsentiert das Merkmal", x_label, ", während die y-Achse die Anzahl der Beschäftigten darstellt. Für jede Ausprägung von", x_label, "ist das Mekrmal", fill_label, "als verschiedenfarbige Balken dargestellt. Die Balken sind nebeneinander angeordnet, um den Vergleich zu erleichtern. Die Farben der Balken entsprechen der Geschlechterzuordnung, wobei eine Legende die Farbcodierung erklärt. Werte der Balken:")
for (i in 1:nrow(data)) {
alttext <- paste(alttext, x_label, data[[x_label]][i], "und", fill_label, data[[fill_label]][i], ":", data[[y_label]][i])
}
alttext
}
balkendiagramm <- function(data, x, y = "Anzahl", fill = "Geschlechtsschluessel", alttext) {
ggplot(data, aes_string(x = x, y = y, fill = fill)) +
geom_col(position = "dodge", color = "white") +
labs(x = x, y = y, fill = fill, alt = alttext) +
scale_fill_discrete(palette = params$farbpalette) +
scale_color_discrete(palette = params$farbpalette) +
theme(text = element_text(family = params$font)) +
theme_minimal()
}
barrierefreies_balkendiagramm <- function(data, x, y = "Anzahl", fill = "Geschlechtsschluessel") {
df <- datenvorbereitung(data, c(x, fill))
print(0)
alttext <- alttexterstellung(df, x, fill, y)
print(1)
balkendiagramm(df, x, y, fill, alttext)
}
