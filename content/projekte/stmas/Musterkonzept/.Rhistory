tabellendatenvorbereitung <- function(data, group_var1, group_vars2) {
data %>%
group_by(across(c(group_var1, group_vars2)) %>%
summarise(Anzahl = n()) %>%
mutate(Anzahl = tabellen_datenschutz(Anzahl)) %>%
pivot_wider(names_from = group_vars2, values_from = Anzahl, values_fill = paste("<", params$kleinstgruppe)) %>%
kable(caption = paste("Personalverteilung nach", paste(group_vars2, collapse = ", "), "und", group_var1)))
}
tabellendatenvorbereitung(daten_beschaeftigungsart, "Beschäftigungsart", "Geschlechtsschluessel"))
